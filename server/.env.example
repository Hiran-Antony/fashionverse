# Server configuration
PORT=5000

# Razorpay credentials (Test Mode / Live Mode)
# Switch these values to production credentials when going live
RAZORPAY_KEY_ID=rzp_test_YourTestKeyIdHere
RAZORPAY_KEY_SECRET=YourRazorpaySecretHere
RAZORPAY_WEBHOOK_SECRET=YourRazorpayWebhookSecretHere

# Supabase configuration (for server-side DB updates)
# Use your service_role key to bypass RLS for secure, server-to-server operations
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
